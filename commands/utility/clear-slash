const { REST, Routes, PermissionFlagsBits } = require("discord.js");

module.exports = {
  name: "clear-slash",
  category: "Admin",
  aliases: ["clearslash", "removeslash"],

  async execute(message, args, client) {
    // Only allow server admins
    if (!message.member.permissions.has(PermissionFlagsBits.Administrator)) {
      return message.reply("❌ You must be an administrator to use this command.");
    }

    const token = process.env.DISCORD_TOKEN;
    const clientId = process.env.CLIENT_ID;

    if (!token || !clientId) {
      return message.reply("❌ CLIENT_ID or DISCORD_TOKEN missing in .env");
    }

    const rest = new REST({ version: "10" }).setToken(token);

    try {
      await rest.put(Routes.applicationCommands(clientId), { body: [] });

      await message.reply("✅ All slash commands have been removed.");
      console.log("✅ Slash commands cleared.");
    } catch (err) {
      console.error(err);
      message.reply("❌ Failed to clear slash commands.");
    }
  },
};
